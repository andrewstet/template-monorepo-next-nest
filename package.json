{
  "name": "template-monorepo-next-nest",
  "description": "Next/Nest Monorepo Template",
  "author": "Andrew Stet",
  "version": "1.0.0",
  "license": "ISC",
  "private": true,
  "pnpm": {
    "overrides": {
      "next>postcss": "8.5.10",
      "terser-webpack-plugin>serialize-javascript": "7.0.5"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.9",
    "eslint": "^9.39.1",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "typescript-eslint": "^8.59.2"
  },
  "scripts": {
    "audit": "pnpm audit --audit-level moderate",
    "audit:prod": "pnpm audit --prod --audit-level moderate",
    "build": "pnpm build:api && pnpm build:web",
    "build:api": "pnpm --filter api build",
    "build:web": "pnpm --filter web build",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "ci:quick": "pnpm check",
    "ci:local": "pnpm check && pnpm build",
    "ci:full": "pnpm ci:local && CI=true pnpm e2e",
    "db:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/docker/docker-compose.yml down",
    "db:logs": "docker compose -f infra/docker/docker-compose.yml logs -f db",
    "db:seed": "pnpm --filter api db:seed",
    "db:migrate": "pnpm --filter api db:migrate",
    "db:migration:create": "pnpm --filter api db:migration:create",
    "db:migration:generate": "pnpm --filter api db:migration:generate",
    "db:migration:run": "pnpm --filter api db:migration:run",
    "db:migration:revert": "pnpm --filter api db:migration:revert",
    "db:reset": "pnpm --filter api db:reset",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api start:dev",
    "dev:setup": "pnpm dev:setup:git",
    "dev:setup:e2e": "pnpm exec playwright install",
    "dev:setup:git": "git config core.hooksPath .githooks && chmod +x .githooks/*",
    "docs:check": "prettier --check \"docs/**/*.md\" && pnpm docs:openapi",
    "docs:openapi": "pnpm --filter api docs:openapi",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "format": "pnpm format:prettier",
    "format:prettier": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,scss,html}\"",
    "lint": "pnpm lint:web && pnpm lint:api",
    "lint:web": "pnpm --filter web lint",
    "lint:api": "pnpm --filter api lint",
    "test": "pnpm test:api && pnpm test:web",
    "test:api": "pnpm --filter api test",
    "test:web": "pnpm --filter web test",
    "typecheck": "pnpm typecheck:api && pnpm typecheck:web",
    "typecheck:api": "pnpm --filter api typecheck",
    "typecheck:web": "pnpm --filter web typecheck"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css,scss,html}": [
      "prettier --write"
    ]
  }
}
