#!/usr/bin/env sh

echo "🪝 Running post-merge hook"

if [ ! -f "apps/api/src/database/data-source.ts" ]; then
  exit 0
fi

if ! command -v pnpm >/dev/null 2>&1; then
  exit 0
fi

if ! pg_isready -h localhost -p 5432 -U db_user >/dev/null 2>&1; then
  echo "   database not running, skipping migrations"

  exit 0
fi

if ! pnpm --filter api db:migration:run; then
  echo "⚠ post-merge: TypeORM migration run failed"
  echo "   Please check your DB/schema and re-run:"
  echo "     pnpm --filter api db:migration:run"
fi

exit 0
