#!/usr/bin/env sh

echo "🪝 Running commit-msg hook"

commit_msg_file="$1"
commit_msg="$(cat "$commit_msg_file")"
valid_types="feat fix chore docs style refactor perf test"
types_regex="$(echo "$valid_types" | sed 's/ /|/g')"

# <type>(<optional-scope>): <message>
pattern="^(${types_regex})(\([a-zA-Z0-9_-]+\))?: .+"

# Allow certain system-generated commits to pass automatically
case "$commit_msg" in
  Merge\ *|Revert\ *|v[0-9]*.[0-9]*.[0-9]*)
    exit 0
    ;;
esac

if ! printf "%s" "$commit_msg" | grep -Eq "$pattern"; then
  echo ""
  echo "❌ Invalid commit message format!"
  echo ""
  echo "Your commit message:"
  echo "  $commit_msg"
  echo ""
  echo "Must follow Conventional Commits format:"
  echo "  <type>(<optional-scope>): <message>"
  echo ""
  echo "Allowed types:"
  echo "  $valid_types"
  echo ""
  echo "Examples:"
  echo "  feat(web): add category filtering"
  echo "  fix(api): correct decimal rounding"
  echo "  chore: update dependencies"
  echo "  docs: update README"
  echo ""

  exit 1
fi

exit 0