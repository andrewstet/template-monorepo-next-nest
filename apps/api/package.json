{
  "name": "api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "db:seed": "tsx src/database/seed/seed-example.ts",
    "db:schema:drop": "typeorm-ts-node-commonjs -d src/database/data-source.ts schema:drop",
    "db:migrate": "pnpm run db:migration:run",
    "db:migration:create": "typeorm-ts-node-commonjs migration:create",
    "db:migration:generate": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:generate",
    "db:migration:run": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:run",
    "db:migration:revert": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:revert",
    "db:reset": "node -e \"if(process.env.NODE_ENV==='production') throw new Error('Refusing to reset in production');\" && pnpm run db:schema:drop && pnpm run db:migration:run && pnpm run db:seed",
    "docs:openapi": "tsx src/openapi.generate.ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --run",
    "test:e2e": "vitest run --config ./vitest.config.e2e.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/typeorm": "^11.0.1",
    "@sentry/node": "^10.52.0",
    "@sentry/profiling-node": "^10.52.0",
    "dotenv": "^17.2.3",
    "nestjs-pino": "^4.5.0",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.30"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@swc/core": "^1.15.33",
    "@types/express": "^5.0.0",
    "@types/node": "^24.12.4",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.5"
  }
}
