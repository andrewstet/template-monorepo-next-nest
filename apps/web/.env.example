NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------- SENTRY ----------
SENTRY_DSN="https://public_key@org.ingest.sentry.io/project"
SENTRY_ENVIRONMENT="development"
SENTRY_RELEASE=""

# You can run Sentry fully server-side without exposing a public DSN,
# but Next commonly uses the public DSN for client-side error capture.
NEXT_PUBLIC_SENTRY_DSN=""
